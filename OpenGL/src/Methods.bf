namespace OpenGL
{
	using System;



	public static class Gl
	{
		public function void* GetProcAddressFunc(StringView procname);
		public static bool hasErrors = false;
		private static GetProcAddressFunc TryGetProcAddress;



		private static void* GetMethod (StringView name)
		{
			var value = TryGetProcAddress(name);
			if (value == null)
			{
				hasErrors = true;
				Console.Error.WriteLine("WARNING: TryGetProcAddress('{0}') returned NULL", name);
			}
			return value;
		}



		public static bool Initialize (GetProcAddressFunc GetProcAddress)
